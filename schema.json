{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Kevin McCoy's Library Catalog",
  "description": "Catalog of books in Kevin McCoy's personal library with intellectual relationships",
  "type": "array",
  "items": {
    "type": "object",
    "title": "Catalog Entry",
    "required": [
      "title",
      "author",
      "year",
      "synopsis",
      "themes"
    ],
    "properties": {
      "title": {
        "type": "string",
        "description": "Book title"
      },
      "author": {
        "type": [
          "string",
          "null"
        ],
        "description": "Author or editor name(s)"
      },
      "year": {
        "type": [
          "integer",
          "null"
        ],
        "description": "Publication year"
      },
      "synopsis": {
        "type": "string",
        "description": "Book description and context"
      },
      "themes": {
        "type": "array",
        "items": {
          "type": "string"
        },
        "description": "Key themes and subjects"
      },
      "source_image": {
        "type": "string",
        "description": "Reference image source"
      },
      "confidence": {
        "type": "string",
        "enum": [
          "high",
          "medium",
          "low"
        ],
        "description": "Confidence level in catalog entry accuracy"
      },
      "needs_review": {
        "type": "boolean",
        "description": "Whether entry needs review or verification"
      },
      "in_conversation_with": {
        "type": "array",
        "items": {
          "type": "string"
        },
        "description": "Titles of related books in the catalog",
        "maxItems": 5
      }
    },
    "additionalProperties": false
  }
}